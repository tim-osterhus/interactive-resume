# API
RAG_API_HOST=127.0.0.1
RAG_API_PORT=8788
RAG_PUBLIC_API_BASE_URL=https://evidence-api.example.com
RAG_ALLOWED_ORIGINS=https://resume.example.com,http://localhost:4173,http://127.0.0.1:4173

# Generation runtime
RAG_GENERATION_PROVIDER=ollama
RAG_GENERATION_BASE_URL=http://127.0.0.1:11434
RAG_GENERATION_TIMEOUT_SECONDS=120
RAG_GENERATION_MAX_TOKENS=768

# Model profiles
RAG_DEFAULT_MODEL_PROFILE=fast
RAG_FAST_MODEL_NAME=replace-with-local-fast-model
RAG_FAST_THINK=false
RAG_FAST_NUM_CTX=8192
RAG_FAST_CONTEXT_MAX_CHARS=6000
RAG_FAST_RETRIEVAL_CANDIDATE_K=20
RAG_FAST_FINAL_SOURCE_COUNT=5
RAG_FAST_GENERATION_MAX_TOKENS=768

RAG_THINKING_MODEL_NAME=replace-with-optional-slower-model
RAG_THINKING_THINK=true
RAG_THINKING_NUM_CTX=8192
RAG_THINKING_CONTEXT_MAX_CHARS=16000
RAG_THINKING_RETRIEVAL_CANDIDATE_K=30
RAG_THINKING_FINAL_SOURCE_COUNT=5
RAG_THINKING_GENERATION_MAX_TOKENS=1024
RAG_THINKING_TIMEOUT_SECONDS=180

# Embeddings
RAG_EMBEDDING_PROVIDER=ollama
RAG_EMBEDDING_BASE_URL=http://127.0.0.1:11434
RAG_EMBEDDING_MODEL=snowflake-arctic-embed2:latest
RAG_EMBEDDING_TRUNCATE_DIM=0

# Corpus and index
RAG_CORPUS_DIR=../raw-corpus
RAG_INDEX_PATH=data/index/sources.json
# The runnable starter uses a tiny JSON index. Replace this with a SQLite/vector
# index setting when building the full RAG version.
# RAG_INDEX_DB_PATH=data/index/evidence.sqlite3
RAG_CORPUS_VERSION=unindexed-dev
RAG_CHUNK_CHARS=1200
RAG_CHUNK_OVERLAP=150

# Public safety limits
RAG_MAX_MESSAGE_CHARS=2000
RAG_MAX_CONTENT_LENGTH_BYTES=8192
RAG_MAX_CONCURRENT_GENERATIONS=1
RAG_MAX_ACTIVE_SESSIONS=2
RAG_SESSION_IDLE_TIMEOUT_SECONDS=600
RAG_MESSAGE_COOLDOWN_SECONDS=15
RAG_MAX_QUEUE_DEPTH=5
RAG_RATE_LIMIT_REQUESTS_PER_MINUTE=20

# Optional job-fit feature
RAG_ENABLE_JOB_FIT=false
RAG_MAX_JOB_DESCRIPTION_CHARS=12000
RAG_LOG_JOB_DESCRIPTIONS=false
