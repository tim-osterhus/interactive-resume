{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Job Fit Request",
  "type": "object",
  "required": ["job_description"],
  "additionalProperties": false,
  "properties": {
    "job_description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 12000
    },
    "role": {
      "type": "string",
      "enum": ["recruiter", "investor", "customer", "builder", "friend"]
    },
    "model_profile": {
      "type": "string",
      "enum": ["fast", "thinking"]
    },
    "session_id": {
      "type": "string",
      "maxLength": 200
    }
  }
}
