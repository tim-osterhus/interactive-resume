{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Interactive Resume SFT Training Row",
  "type": "object",
  "required": ["id", "role", "messages", "sources", "answer"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "role": {
      "type": "string",
      "enum": ["recruiter", "investor", "customer", "builder", "friend"]
    },
    "mode": {
      "type": "string",
      "enum": ["built", "proof", "limits"]
    },
    "question_family": {
      "type": "string"
    },
    "messages": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["role", "content"],
        "additionalProperties": false,
        "properties": {
          "role": {
            "type": "string",
            "enum": ["system", "user", "assistant"]
          },
          "content": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "excerpt"],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^S[0-9]+$"
          },
          "title": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "excerpt": {
            "type": "string"
          },
          "source_slug": {
            "type": "string"
          }
        }
      }
    },
    "answer": {
      "type": "string",
      "minLength": 1
    },
    "review": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
