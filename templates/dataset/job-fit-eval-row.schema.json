{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Job Fit Eval Row",
  "type": "object",
  "required": ["id", "job_description", "expected"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "role": {
      "type": "string",
      "enum": ["recruiter", "investor", "customer", "builder", "friend"]
    },
    "job_description": {
      "type": "string",
      "minLength": 1
    },
    "expected": {
      "type": "object",
      "required": ["supported", "missing"],
      "additionalProperties": false,
      "properties": {
        "supported": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "partial": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "missing": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "forbidden_claims": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "expected_source_tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
